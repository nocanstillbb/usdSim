{
  "mcpServers": {
    "playqmlright": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "playqmlright/playqmlright",
        "python",
        "playqmlright/playqmlright/server.py"
      ],
      "env": {
        "QML_INSPECTOR_SOCKET": "127.0.0.1:37521"
      }
    },
    "context7-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "playwright-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  }
}
